# Names only. Never put real values in Git.

APP_ENV=local
KLICKIT_CLINIC_CODE=DEV
KLICKIT_GATEWAY_CODE=DEV-GW-01
KLICKIT_SOFTWARE_VERSION=0.0.0

# Local gateway database (defaults to Supabase local stack port 54322 in development)
GATEWAY_DATABASE_URL=
DATABASE_URL=

# Gateway HTTP bind
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8787
GATEWAY_LOG_LEVEL=info
GATEWAY_LAN_DISCOVERY=true

# Optional cloud sync receiver URL for development
KLICKIT_CLOUD_SYNC_URL=

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

PABBLY_WEBHOOK_SECRET=
